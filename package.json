{
  "name": "parallel-ui",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @parallel-ui/playground-web",
    "dev:mobile": "npm run dev -w @parallel-ui/playground-web -- --host 0.0.0.0 --port 4173",
    "dev:native": "npm run start -w @parallel-ui/playground-native",
    "build": "npm run build -w @parallel-ui/book-object",
    "build:book-object": "npm run build -w @parallel-ui/book-object",
    "build:playground": "npm run build -w @parallel-ui/playground-web",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.1.0",
    "expo": "54.0.33",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8",
    "typescript": "~5.9.3"
  }
}
